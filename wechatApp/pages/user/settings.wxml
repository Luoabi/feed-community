<view class="container">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="page-title">设置</text>
  </view>

  <!-- 账号设置 -->
  <view class="section">
    <view class="section-title">账号设置</view>
    <view class="setting-list">
      <view class="setting-item" bindtap="onChangePassword">
        <view class="setting-left">
          <text class="setting-icon">🔒</text>
          <text class="setting-text">修改密码</text>
        </view>
        <text class="setting-arrow">›</text>
      </view>
      <view class="setting-item" bindtap="onBindPhone">
        <view class="setting-left">
          <text class="setting-icon">📱</text>
          <text class="setting-text">绑定手机</text>
        </view>
        <view class="setting-right">
          <text class="setting-value">{{userInfo.phone || '未绑定'}}</text>
          <text class="setting-arrow">›</text>
        </view>
      </view>
      <view class="setting-item" bindtap="onBindEmail">
        <view class="setting-left">
          <text class="setting-icon">📧</text>
          <text class="setting-text">绑定邮箱</text>
        </view>
        <view class="setting-right">
          <text class="setting-value">{{userInfo.email || '未绑定'}}</text>
          <text class="setting-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 通知设置 -->
  <view class="section">
    <view class="section-title">通知设置</view>
    <view class="setting-list">
      <view class="setting-item">
        <view class="setting-left">
          <text class="setting-icon">🔔</text>
          <text class="setting-text">点赞通知</text>
        </view>
        <switch checked="{{settings.likeNotify}}" bindchange="onLikeNotifyChange" color="#667eea"/>
      </view>
      <view class="setting-item">
        <view class="setting-left">
          <text class="setting-icon">💬</text>
          <text class="setting-text">评论通知</text>
        </view>
        <switch checked="{{settings.commentNotify}}" bindchange="onCommentNotifyChange" color="#667eea"/>
      </view>
      <view class="setting-item">
        <view class="setting-left">
          <text class="setting-icon">👥</text>
          <text class="setting-text">关注通知</text>
        </view>
        <switch checked="{{settings.followNotify}}" bindchange="onFollowNotifyChange" color="#667eea"/>
      </view>
    </view>
  </view>

  <!-- 隐私设置 -->
  <view class="section">
    <view class="section-title">隐私设置</view>
    <view class="setting-list">
      <view class="setting-item">
        <view class="setting-left">
          <text class="setting-icon">🔐</text>
          <text class="setting-text">私密账号</text>
        </view>
        <switch checked="{{settings.privateAccount}}" bindchange="onPrivateAccountChange" color="#667eea"/>
      </view>
      <view class="setting-item">
        <view class="setting-left">
          <text class="setting-icon">👁️</text>
          <text class="setting-text">显示在线状态</text>
        </view>
        <switch checked="{{settings.showOnlineStatus}}" bindchange="onShowOnlineStatusChange" color="#667eea"/>
      </view>
    </view>
  </view>

  <!-- 其他设置 -->
  <view class="section">
    <view class="section-title">其他</view>
    <view class="setting-list">
      <view class="setting-item" bindtap="onClearCache">
        <view class="setting-left">
          <text class="setting-icon">🗑️</text>
          <text class="setting-text">清除缓存</text>
        </view>
        <view class="setting-right">
          <text class="setting-value">{{cacheSize}}</text>
          <text class="setting-arrow">›</text>
        </view>
      </view>
      <view class="setting-item" bindtap="onCheckUpdate">
        <view class="setting-left">
          <text class="setting-icon">🔄</text>
          <text class="setting-text">检查更新</text>
        </view>
        <view class="setting-right">
          <text class="setting-value">v1.0.0</text>
          <text class="setting-arrow">›</text>
        </view>
      </view>
    </view>
  </view>
</view>
