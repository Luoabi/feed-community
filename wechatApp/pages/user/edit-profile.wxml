<view class="container">
  <view class="form-section">
    <!-- 头像 -->
    <view class="form-item">
      <text class="label">头像</text>
      <view class="avatar-upload" bindtap="onChooseAvatar">
        <image class="avatar-preview" src="{{formData.avatar || '/images/default-avatar.svg'}}"/>
        <view class="upload-mask" wx:if="{{uploading}}">
          <text class="upload-text">上传中...</text>
        </view>
        <text class="upload-hint" wx:if="{{!uploading}}">点击更换</text>
      </view>
    </view>

    <!-- 昵称 -->
    <view class="form-item">
      <text class="label">昵称</text>
      <input 
        class="input" 
        value="{{formData.nickname}}" 
        placeholder="请输入昵称"
        maxlength="20"
        bindinput="onNicknameInput"
      />
    </view>

    <!-- 性别 -->
    <view class="form-item">
      <text class="label">性别</text>
      <view class="gender-selector">
        <view 
          class="gender-option {{formData.gender === 1 ? 'active' : ''}}"
          bindtap="onGenderChange"
          data-gender="1"
        >
          <text class="gender-icon">👨</text>
          <text class="gender-text">男</text>
        </view>
        <view 
          class="gender-option {{formData.gender === 2 ? 'active' : ''}}"
          bindtap="onGenderChange"
          data-gender="2"
        >
          <text class="gender-icon">👩</text>
          <text class="gender-text">女</text>
        </view>
        <view 
          class="gender-option {{formData.gender === 0 ? 'active' : ''}}"
          bindtap="onGenderChange"
          data-gender="0"
        >
          <text class="gender-icon">🤷</text>
          <text class="gender-text">保密</text>
        </view>
      </view>
    </view>

    <!-- 个人简介 -->
    <view class="form-item">
      <text class="label">个人简介</text>
      <textarea 
        class="textarea" 
        value="{{formData.bio}}" 
        placeholder="介绍一下自己吧~"
        maxlength="200"
        bindinput="onBioInput"
        show-confirm-bar="{{false}}"
      />
      <text class="char-count">{{bioLength}}/200</text>
    </view>

    <!-- 手机号 -->
    <view class="form-item">
      <text class="label">手机号</text>
      <input 
        class="input" 
        value="{{formData.phone}}" 
        placeholder="请输入手机号"
        type="number"
        maxlength="11"
        bindinput="onPhoneInput"
      />
    </view>

    <!-- 邮箱 -->
    <view class="form-item">
      <text class="label">邮箱</text>
      <input 
        class="input" 
        value="{{formData.email}}" 
        placeholder="请输入邮箱"
        type="text"
        bindinput="onEmailInput"
      />
    </view>
  </view>

  <!-- 保存按钮 -->
  <view class="btn-container">
    <button class="save-btn" bindtap="onSave" disabled="{{saving}}">
      {{saving ? '保存中...' : '保存'}}
    </button>
  </view>
</view>
