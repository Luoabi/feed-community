.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* ✅ 状态筛选器样式 */
.filter-bar {
  display: flex;
  background: white;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #666;
  border-radius: 8rpx;
  transition: all 0.3s;
}

.filter-item.active {
  background: #1890ff;
  color: white;
  font-weight: 600;
}

.posts-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 0 20rpx 20rpx;
}

.post-item {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
}

.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.author-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.author-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.author-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.post-time {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* ✅ 审核状态标识样式 */
.status-badge {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  margin-right: 12rpx;
  white-space: nowrap;
}

.status-pending {
  background: #fff7e6;
  color: #fa8c16;
  border: 1px solid #ffd591;
}

.status-published {
  background: #f6ffed;
  color: #52c41a;
  border: 1px solid #b7eb8f;
}

.status-rejected {
  background: #fff1f0;
  color: #ff4d4f;
  border: 1px solid #ffccc7;
}

.status-draft {
  background: #f5f5f5;
  color: #999;
  border: 1px solid #d9d9d9;
}

.delete-btn {
  padding: 8rpx 24rpx;
  font-size: 24rpx;
  background: #ff4d4f;
  color: white;
  border-radius: 8rpx;
  border: none;
}

.post-content {
  margin-bottom: 20rpx;
}

.post-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.post-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

/* ✅ 拒绝原因样式 */
.reject-reason {
  margin-top: 20rpx;
  padding: 20rpx;
  background: #fff1f0;
  border-left: 4rpx solid #ff4d4f;
  border-radius: 8rpx;
}

.reject-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.reject-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.reject-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #ff4d4f;
}

.reject-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

.post-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.post-image {
  width: 220rpx;
  height: 220rpx;
  border-radius: 12rpx;
}

.post-stats {
  display: flex;
  gap: 40rpx;
  padding-top: 20rpx;
  border-top: 1px solid #f0f0f0;
}

.stat-item {
  font-size: 24rpx;
  color: #999;
}

.empty-tip, .loading-tip {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}
