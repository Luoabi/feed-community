<view class="container">
  <!-- 未登录状态 -->
  <view class="login-prompt" wx:if="{{!isLogin}}">
    <image class="avatar-placeholder" src="/images/default-avatar.svg"/>
    <text class="prompt-text">登录后查看更多内容</text>
    <button class="login-btn" bindtap="onLoginTap">立即登录</button>
  </view>

  <!-- 已登录状态 -->
  <view class="user-container" wx:else>
    <!-- 用户信息 -->
    <view class="user-header">
      <view class="header-bg"></view>
      <view class="header-content">
        <image class="avatar" src="{{userInfo.avatar || '/images/default-avatar.svg'}}"/>
        <view class="user-info">
          <text class="nickname">{{userInfo.nickname || userInfo.username}}</text>
          <text class="user-id">ID: {{userInfo.id}}</text>
          <text class="user-bio" wx:if="{{userInfo.bio}}">{{userInfo.bio}}</text>
        </view>
        <view class="edit-btn" bindtap="onEditProfileTap">
          <text class="edit-icon">✏️</text>
        </view>
      </view>
    </view>

    <!-- 统计数据 -->
    <view class="stats-container">
      <view class="stat-item" bindtap="onMyPostsTap">
        <text class="stat-value">{{stats.posts}}</text>
        <text class="stat-label">发布</text>
      </view>
      <view class="stat-item" bindtap="onMyLikesTap">
        <text class="stat-value">{{stats.likes}}</text>
        <text class="stat-label">点赞</text>
      </view>
      <view class="stat-item" bindtap="onMyCollectsTap">
        <text class="stat-value">{{stats.collects}}</text>
        <text class="stat-label">收藏</text>
      </view>
    </view>

    <!-- 功能菜单 -->
    <view class="menu-list">
      <view class="menu-item" bindtap="onMyPostsTap">
        <text class="menu-icon">📝</text>
        <text class="menu-text">我的发布</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="onMyLikesTap">
        <text class="menu-icon">❤️</text>
        <text class="menu-text">我的点赞</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="onMyCollectsTap">
        <text class="menu-icon">⭐</text>
        <text class="menu-text">我的收藏</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-divider"/>
      <view class="menu-item" bindtap="onSettingsTap">
        <text class="menu-icon">⚙️</text>
        <text class="menu-text">设置</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="onAboutTap">
        <text class="menu-icon">ℹ️</text>
        <text class="menu-text">关于我们</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <!-- 退出登录 -->
    <button class="logout-btn" bindtap="onLogoutTap">退出登录</button>
  </view>
</view>
