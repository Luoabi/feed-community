page {
  background: linear-gradient(180deg, #f5f7fa 0%, #ffffff 100%);
}

.container {
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* 应用头部 */
.app-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0 60rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 0 0 60rpx 60rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.2);
}

.app-logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 40rpx;
  background: #fff;
  padding: 20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.app-name {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.app-version {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 16rpx;
}

.app-slogan {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
  letter-spacing: 2rpx;
}

/* 区块样式 */
.section {
  margin-bottom: 32rpx;
}

.section-title {
  padding: 0 32rpx 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.section-content {
  background: #fff;
  padding: 32rpx;
  margin: 0 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.intro-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  text-align: justify;
}

/* 功能特色 */
.feature-list {
  background: #fff;
  padding: 24rpx;
  margin: 0 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.feature-item {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  margin-bottom: 16rpx;
  background: linear-gradient(135deg, #f8f9ff 0%, #fafbff 100%);
  border-radius: 12rpx;
  border-left: 6rpx solid #667eea;
}

.feature-item:last-child {
  margin-bottom: 0;
}

.feature-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.feature-info {
  flex: 1;
}

.feature-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.feature-desc {
  display: block;
  font-size: 26rpx;
  color: #999;
  line-height: 1.6;
}

/* 联系我们 */
.contact-list {
  background: #fff;
  margin: 0 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.contact-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
  transition: background-color 0.2s;
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-item:active {
  background-color: #f8f9fa;
}

.contact-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.contact-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.contact-text {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.contact-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.contact-value {
  font-size: 26rpx;
  color: #667eea;
  font-weight: 600;
}

.contact-action {
  font-size: 24rpx;
  color: #999;
  padding: 8rpx 16rpx;
  background: #f5f7fa;
  border-radius: 20rpx;
}

/* 法律信息 */
.legal-list {
  background: #fff;
  margin: 0 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.legal-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
  transition: background-color 0.2s;
}

.legal-item:last-child {
  border-bottom: none;
}

.legal-item:active {
  background-color: #f8f9fa;
}

.legal-text {
  font-size: 30rpx;
  color: #333;
}

.legal-arrow {
  font-size: 36rpx;
  color: #ccc;
  font-weight: 300;
}

/* 版权信息 */
.copyright {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 32rpx;
  gap: 12rpx;
}

.copyright-text {
  font-size: 24rpx;
  color: #999;
  text-align: center;
}

/* 反馈按钮 */
.feedback-btn {
  position: fixed;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 48rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 60rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
  transition: all 0.3s;
}

.feedback-btn:active {
  transform: translateX(-50%) scale(0.95);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.4);
}

.feedback-icon {
  font-size: 32rpx;
}

.feedback-text {
  font-size: 28rpx;
  font-weight: 600;
}
