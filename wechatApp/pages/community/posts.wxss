page {
  background: #f8f9fa;
}

.container {
  width: 100%;
  min-height: 100vh;
  position: relative;
  background: linear-gradient(180deg, #fff5f7 0%, #fafbff 50%, #f8f9fa 100%);
}

/* 顶部装饰背景 - 社区主题色 */
.header-decoration {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 500rpx;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 50%, #ff6b9d 100%);
  z-index: 0;
  overflow: hidden;
}

/* 添加动态波浪装饰 */
.header-decoration::before {
  content: '';
  position: absolute;
  top: -80rpx;
  left: -100rpx;
  width: 600rpx;
  height: 600rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.15) 0%, transparent 70%);
  border-radius: 50%;
  animation: wave 10s ease-in-out infinite;
}

.header-decoration::after {
  content: '';
  position: absolute;
  bottom: -100rpx;
  right: -80rpx;
  width: 500rpx;
  height: 500rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.12) 0%, transparent 70%);
  border-radius: 50%;
  animation: wave 12s ease-in-out infinite reverse;
}

@keyframes wave {
  0%, 100% {
    transform: translate(0, 0) rotate(0deg);
  }
  50% {
    transform: translate(40rpx, -40rpx) rotate(180deg);
  }
}

/* 帖子列表 */
.post-list {
  padding: 24rpx;
  position: relative;
  z-index: 1;
}

.post-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(240, 147, 251, 0.08);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  border: 1rpx solid rgba(240, 147, 251, 0.1);
  background: linear-gradient(180deg, #ffffff 0%, #fffafc 100%);
}

.post-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(240, 147, 251, 0.12);
}

/* 帖子头部 */
.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.author-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  border: 3rpx solid rgba(240, 147, 251, 0.15);
  box-shadow: 0 4rpx 12rpx rgba(240, 147, 251, 0.15);
}

.author-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.author-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.create-time {
  font-size: 24rpx;
  color: #999;
}

/* 帖子内容 */
.post-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.5;
  margin-bottom: 16rpx;
  word-break: break-word;
}

.post-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.7;
  margin-bottom: 24rpx;
  word-break: break-word;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 6;
  overflow: hidden;
}

/* 图片帖子的文字描述 - 显示在图片下方，行数限制更少 */
.post-content-with-images {
  margin-top: 16rpx;
  margin-bottom: 24rpx;
  -webkit-line-clamp: 3;
  font-size: 26rpx;
  color: #666;
}

/* ==================== 链接类型样式 ==================== */
.post-link-preview {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #fff5f7 0%, #ffe8f0 100%);
  border-radius: 16rpx;
  border: 2rpx solid rgba(240, 147, 251, 0.2);
  margin-bottom: 16rpx;
  transition: all 0.3s ease;
}

.post-card:active .post-link-preview {
  background: linear-gradient(135deg, #ffe8f0 0%, #ffd6e7 100%);
  transform: scale(0.98);
}

.link-icon {
  font-size: 64rpx;
  flex-shrink: 0;
  filter: drop-shadow(0 4rpx 8rpx rgba(240, 147, 251, 0.2));
}

.link-info {
  flex: 1;
  min-width: 0;
}

.link-url {
  font-size: 26rpx;
  color: #f093fb;
  font-weight: 600;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-decoration: underline;
}

.link-hint {
  font-size: 22rpx;
  color: #999;
  font-weight: 500;
}

/* ==================== 视频类型样式 ==================== */
.post-video-preview {
  position: relative;
  width: 100%;
  height: 400rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #f0f2f5 0%, #e8ecf1 100%);
  margin-bottom: 16rpx;
}

.video-thumb {
  width: 100%;
  height: 100%;
}

.video-play-icon {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 80rpx;
  filter: drop-shadow(0 4rpx 12rpx rgba(0, 0, 0, 0.3));
}

.video-duration {
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  background: rgba(0, 0, 0, 0.7);
  color: #fff;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
}

/* 图片网格 - 智能布局 */
.post-images {
  margin-bottom: 0;
  border-radius: 16rpx;
  overflow: hidden;
}

.images-grid {
  display: grid;
  gap: 8rpx;
}

/* 1张图片 - 大图 */
.images-1 {
  grid-template-columns: 1fr;
}

.images-1 .post-image {
  width: 100%;
  height: 400rpx;
}

/* 2张图片 - 横向排列 */
.images-2 {
  grid-template-columns: repeat(2, 1fr);
}

.images-2 .post-image {
  width: 100%;
  height: 280rpx;
}

/* 3张图片 - 横向排列 */
.images-3 {
  grid-template-columns: repeat(3, 1fr);
}

.images-3 .post-image {
  width: 100%;
  height: 200rpx;
}

/* 4张及以上 - 3列网格 */
.images-more {
  grid-template-columns: repeat(3, 1fr);
}

.images-more .post-image {
  width: 100%;
  height: 200rpx;
}

.post-image {
  border-radius: 12rpx;
  background: linear-gradient(135deg, #fff5f7 0%, #ffe8f0 100%);
  transition: transform 0.3s;
  box-shadow: 0 2rpx 8rpx rgba(240, 147, 251, 0.1);
}

.post-image:active {
  transform: scale(0.95);
}

/* 统计信息 */
.post-stats {
  display: flex;
  align-items: center;
  gap: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(240, 147, 251, 0.1);
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  transition: transform 0.2s;
}

.stat-item:active {
  transform: scale(0.95);
}

.stat-icon {
  font-size: 32rpx;
}

.stat-text {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
}

/* 加载状态 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(240, 147, 251, 0.1);
  border-top-color: #f093fb;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #999;
}

/* 没有更多 */
.no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
  gap: 20rpx;
}

.no-more-line {
  width: 80rpx;
  height: 1rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(240, 147, 251, 0.3) 50%, transparent 100%);
}

.no-more-text {
  font-size: 26rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 140rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
}
