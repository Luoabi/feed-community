<view class="container">
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <view class="post-detail" wx:else>
    <!-- 帖子头部 -->
    <view class="post-header">
      <image class="author-avatar" src="{{post.authorAvatar || '/images/default-avatar.svg'}}"/>
      <view class="author-info">
        <text class="author-name">{{post.authorName}}</text>
        <text class="create-time">{{post.createTime}}</text>
      </view>
    </view>

    <!-- 帖子标题 -->
    <view class="post-title">{{post.title}}</view>

    <!-- 帖子内容 -->
    <view class="post-content">{{post.content}}</view>

    <!-- 链接（根据 linkUrl 字段判断） -->
    <view class="post-link" wx:if="{{post.linkUrl}}">
      <view class="link-card">
        <view class="link-icon">🔗</view>
        <view class="link-info">
          <view class="link-label">链接地址</view>
          <view class="link-url">{{post.linkUrl}}</view>
        </view>
      </view>
      <button class="copy-link-btn" data-url="{{post.linkUrl}}" bindtap="onCopyLink">复制链接</button>
    </view>

    <!-- 图片列表 -->
    <view class="post-images" wx:if="{{post.images && post.images.length > 0}}">
      <image 
        class="post-image" 
        src="{{img}}" 
        wx:for="{{post.images}}" 
        wx:for-item="img"
        wx:key="*this"
        mode="aspectFill"
        data-url="{{img}}"
        bindtap="onImagePreview"
      />
    </view>

    <!-- 视频 -->
    <video 
      wx:if="{{post.videoUrl}}"
      class="post-video" 
      src="{{post.videoUrl}}"
      poster="{{post.coverImage}}"
      controls
      show-center-play-btn
      show-fullscreen-btn
    />

    <!-- 统计信息 -->
    <view class="post-stats">
      <text class="stat">👁 {{post.views}}</text>
      <text class="stat">❤️ {{post.likes}}</text>
      <text class="stat">💬 {{post.comments}}</text>
      <text class="stat">🔗 {{post.shares}}</text>
    </view>

    <!-- 操作栏 -->
    <view class="action-bar">
      <view class="action-item" bindtap="onLikeTap">
        <text class="action-icon {{isLiked ? 'active' : ''}}">❤️</text>
        <text class="action-text">点赞</text>
      </view>
      <view class="action-item">
        <text class="action-icon">💬</text>
        <text class="action-text">评论</text>
      </view>
      <button class="action-item" open-type="share">
        <text class="action-icon">🔗</text>
        <text class="action-text">分享</text>
      </button>
    </view>

    <!-- 评论列表 -->
    <view class="comments-section">
      <view class="section-title">评论 ({{comments.length}})</view>
      <view class="comment-list">
        <view class="comment-item" wx:for="{{comments}}" wx:key="id">
          <image class="comment-avatar" src="{{item.userAvatar || '/images/default-avatar.svg'}}"/>
          <view class="comment-content">
            <text class="comment-user">{{item.userName}}</text>
            <text class="comment-text">{{item.content}}</text>
            <view class="comment-meta">
              <text class="comment-time">{{item.createTime}}</text>
              <text class="comment-likes">❤️ {{item.likes}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 评论输入框 -->
    <view class="comment-input-bar">
      <input 
        class="comment-input" 
        placeholder="说点什么..." 
        value="{{commentText}}"
        bindinput="onCommentInput"
      />
      <button class="send-btn" bindtap="onCommentSubmit">发送</button>
    </view>
  </view>
</view>
