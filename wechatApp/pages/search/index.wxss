page {
  background: #f7f8fa;
  height: 100%;
}

.container {
  width: 100%;
  min-height: 100%;
  background: #f7f8fa;
}

/* ==================== 搜索头部 ==================== */
.search-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 32rpx;
  background: #fff;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.03);
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f7f8fa;
  border-radius: 48rpx;
  padding: 20rpx 32rpx;
  transition: all 0.3s ease;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  opacity: 0.6;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.clear-icon {
  font-size: 32rpx;
  color: #999;
  padding: 0 8rpx;
  transition: all 0.3s ease;
}

.clear-icon:active {
  transform: scale(0.9);
}

.cancel-btn {
  font-size: 28rpx;
  color: #667eea;
  font-weight: 500;
  padding: 8rpx 0;
}

/* ==================== 搜索建议 ==================== */
.search-suggest {
  background: #fff;
  margin-top: 16rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  margin: 16rpx 32rpx;
}

.suggest-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: all 0.3s ease;
}

.suggest-item:last-child {
  border-bottom: none;
}

.suggest-item:active {
  background: #f7f8fa;
}

.suggest-icon {
  font-size: 28rpx;
  margin-right: 20rpx;
  opacity: 0.5;
}

.suggest-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

/* ==================== 搜索前显示 ==================== */
.search-before {
  padding: 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.clear-history {
  font-size: 26rpx;
  color: #999;
  padding: 8rpx 16rpx;
}

.hot-icon {
  font-size: 28rpx;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.2);
  }
}

/* ==================== 搜索历史 ==================== */
.history-section {
  margin-bottom: 48rpx;
}

.history-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.history-tag {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 28rpx;
  background: #fff;
  border-radius: 48rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s ease;
}

.history-tag:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.tag-text {
  font-size: 26rpx;
  color: #666;
}

.tag-close {
  font-size: 24rpx;
  color: #999;
  padding: 0 4rpx;
}

/* ==================== 热门搜索 ==================== */
.hot-section {
  margin-bottom: 32rpx;
}

.hot-tags {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.hot-tag {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 28rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s ease;
}

.hot-tag:active {
  transform: translateX(8rpx);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.15);
}

.hot-tag-top {
  background: linear-gradient(135deg, #fff5f5 0%, #fff 100%);
  border-left: 6rpx solid #ff6b6b;
}

.tag-rank {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8787 100%);
  border-radius: 50%;
  flex-shrink: 0;
}

.hot-tag .tag-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* ==================== 搜索结果 ==================== */
.search-results {
  padding: 0 32rpx 32rpx;
}

.result-header {
  padding: 32rpx 0 24rpx;
}

.result-count {
  font-size: 26rpx;
  color: #999;
}

/* ==================== 内容卡片 ==================== */
.content-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.content-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s ease;
}

.content-card:active {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.12);
}

/* 有图片的卡片 */
.card-with-image {
  display: flex;
  padding: 28rpx;
  gap: 24rpx;
}

.card-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.card-image {
  width: 200rpx;
  height: 150rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #f5f5f5;
}

/* 无图片的卡片 */
.card-no-image {
  padding: 28rpx;
}

.content-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.5;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  word-break: break-word;
}

.content-summary {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  word-break: break-word;
}

.content-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-wrap: wrap;
}

.meta-item {
  font-size: 24rpx;
  color: #999;
}

.meta-dot {
  font-size: 24rpx;
  color: #ddd;
}

/* ==================== 加载状态 ==================== */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 5rpx solid rgba(102, 126, 234, 0.1);
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 0.8s cubic-bezier(0.68, -0.55, 0.265, 1.55) infinite;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.15);
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #999;
  font-weight: 500;
}

/* ==================== 没有更多 ==================== */
.no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  gap: 24rpx;
}

.no-more-line {
  width: 100rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(102, 126, 234, 0.3) 50%, transparent 100%);
}

.no-more-text {
  font-size: 26rpx;
  color: #999;
  font-weight: 500;
  letter-spacing: 2rpx;
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 140rpx;
  margin-bottom: 32rpx;
  opacity: 0.4;
  filter: grayscale(0.3);
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  font-weight: 500;
  letter-spacing: 1rpx;
  margin-bottom: 16rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: #bbb;
}
