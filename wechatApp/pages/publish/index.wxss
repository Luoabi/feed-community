.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 20rpx;
}

/* 顶部标题 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 20rpx 30rpx;
}

.header-content {
  flex: 1;
}

.header-title {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.title-icon {
  font-size: 48rpx;
  margin-right: 12rpx;
}

.title-text {
  font-size: 40rpx;
  font-weight: 700;
  color: white;
}

.header-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 草稿按钮 - 优化样式 */
.draft-actions {
  display: flex;
  gap: 12rpx;
}

.draft-btn {
  width: 72rpx;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10rpx);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.draft-btn:active {
  transform: scale(0.9);
  background: rgba(255, 255, 255, 0.3);
}

.draft-icon {
  font-size: 36rpx;
}

/* 表单容器 */
.publish-form {
  background: white;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

/* 区块标签 */
.section-label {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.label-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.label-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
}

.required-tag {
  font-size: 20rpx;
  color: #ff4d4f;
  background: rgba(255, 77, 79, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
}

.optional-tag {
  font-size: 20rpx;
  color: #999;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
}

.char-count,
.media-count,
.tag-count {
  font-size: 24rpx;
  color: #999;
}

/* 类型选择卡片 */
.type-section {
  margin-bottom: 32rpx;
}

.type-cards {
  display: flex;
  gap: 16rpx;
}

.type-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 12rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  border: 3rpx solid transparent;
  transition: all 0.3s;
}

.type-card.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-color: #667eea;
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 16rpx rgba(102, 126, 234, 0.3);
}

.type-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.type-card.active .type-icon {
  filter: brightness(1.2);
}

.type-name {
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
}

.type-card.active .type-name {
  color: white;
  font-weight: 600;
}

/* 输入区域 */
.input-section {
  margin-bottom: 32rpx;
}

.title-input,
.link-input {
  width: 100%;
  height: 88rpx;
  background: #f8f9fa;
  border: 2rpx solid #e8e8e8;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  transition: all 0.3s;
}

.title-input:focus,
.link-input:focus {
  background: white;
  border-color: #667eea;
  box-shadow: 0 0 0 6rpx rgba(102, 126, 234, 0.1);
}

.content-textarea {
  width: 100%;
  min-height: 320rpx;
  background: #f8f9fa;
  border: 2rpx solid #e8e8e8;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  transition: all 0.3s;
}

.content-textarea:focus {
  background: white;
  border-color: #667eea;
  box-shadow: 0 0 0 6rpx rgba(102, 126, 234, 0.1);
}

.placeholder {
  color: #bbb;
}

/* 图片网格 */
.media-section {
  margin-bottom: 32rpx;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 100%;
  padding-bottom: 100%;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.delete-badge {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 48rpx;
  height: 48rpx;
  background: rgba(255, 77, 79, 0.95);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(255, 77, 79, 0.4);
}

.delete-icon {
  color: white;
  font-size: 36rpx;
  font-weight: 600;
  line-height: 1;
}

.add-image-card {
  width: 100%;
  padding-bottom: 100%;
  position: relative;
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  border: 3rpx dashed #d0d0d0;
  border-radius: 16rpx;
  transition: all 0.3s;
}

.add-image-card:active {
  transform: scale(0.95);
  border-color: #667eea;
}

.add-icon-wrapper {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.add-icon {
  font-size: 64rpx;
  color: #999;
  line-height: 1;
  margin-bottom: 8rpx;
}

.add-text {
  font-size: 22rpx;
  color: #999;
}

/* 视频区域 */
.video-wrapper {
  position: relative;
}

.video-player {
  width: 100%;
  height: 400rpx;
  border-radius: 16rpx;
  background: #000;
}

.remove-video-btn {
  width: 100%;
  height: 72rpx;
  margin-top: 16rpx;
  background: #fff;
  border: 2rpx solid #ff4d4f;
  border-radius: 12rpx;
  color: #ff4d4f;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.upload-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  border: 3rpx dashed #d0d0d0;
  border-radius: 16rpx;
  transition: all 0.3s;
}

.upload-card:active {
  transform: scale(0.98);
  border-color: #667eea;
}

.upload-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.upload-text {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.upload-hint {
  font-size: 24rpx;
  color: #999;
}

/* 发布按钮 */
.action-section {
  margin-top: 48rpx;
}

.publish-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border: none;
  border-radius: 48rpx;
  color: white;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
  transition: all 0.3s;
}

.publish-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.publish-btn.publishing {
  background: linear-gradient(135deg, #95a5f5 0%, #a88bc4 100%);
  box-shadow: none;
}

.publish-btn[disabled] {
  background: #e0e0e0;
  color: #999;
  box-shadow: none;
}

.btn-icon {
  font-size: 32rpx;
}

.btn-text {
  font-size: 32rpx;
}

/* 分类选择器 */
.picker-display {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  background: #f8f9fa;
  border: 2rpx solid #e8e8e8;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.picker-display .selected {
  color: #333;
}

.picker-display .placeholder {
  color: #bbb;
}

.picker-arrow {
  font-size: 32rpx;
  color: #999;
  transform: rotate(90deg);
}

/* 标签选择器 */
.tag-section {
  margin-bottom: 32rpx;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  padding: 12rpx 24rpx;
  background: #f8f9fa;
  border: 2rpx solid #e8e8e8;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.3s;
}

.tag-item.selected {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-color: #667eea;
  color: white;
  transform: scale(1.05);
}

.tag-name {
  font-size: 26rpx;
}

/* 发布提示 */
.publish-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 24rpx;
  gap: 8rpx;
}

.hint-icon {
  font-size: 28rpx;
}

.hint-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}
