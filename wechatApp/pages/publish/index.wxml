<view class="container">
  <!-- 顶部标题栏 -->
  <view class="header">
    <view class="header-content">
      <view class="header-title">
        <text class="title-icon">✨</text>
        <text class="title-text">创作新内容</text>
      </view>
      <view class="header-subtitle">分享你的精彩瞬间</view>
    </view>
    <!-- 草稿按钮 - 优化样式 -->
    <view class="draft-actions">
      <view class="draft-btn" bindtap="onLoadDraft">
        <text class="draft-icon">📄</text>
      </view>
      <view class="draft-btn" bindtap="onSaveDraft">
        <text class="draft-icon">💾</text>
      </view>
    </view>
  </view>

  <view class="publish-form">
    <!-- 帖子类型选择 - 卡片式 -->
    <view class="type-section">
      <view class="section-label">
        <text class="label-icon">📝</text>
        <text class="label-text">内容类型</text>
      </view>
      <view class="type-cards">
        <view 
          class="type-card {{contentType === 'text' ? 'active' : ''}}" 
          bindtap="onTypeSelect"
          data-type="text"
        >
          <text class="type-icon">📄</text>
          <text class="type-name">文本</text>
        </view>
        <view 
          class="type-card {{contentType === 'image' ? 'active' : ''}}" 
          bindtap="onTypeSelect"
          data-type="image"
        >
          <text class="type-icon">🖼️</text>
          <text class="type-name">图片</text>
        </view>
        <view 
          class="type-card {{contentType === 'video' ? 'active' : ''}}" 
          bindtap="onTypeSelect"
          data-type="video"
        >
          <text class="type-icon">🎬</text>
          <text class="type-name">视频</text>
        </view>
        <view 
          class="type-card {{contentType === 'link' ? 'active' : ''}}" 
          bindtap="onTypeSelect"
          data-type="link"
        >
          <text class="type-icon">🔗</text>
          <text class="type-name">链接</text>
        </view>
      </view>
    </view>

    <!-- 分类选择 -->
    <view class="input-section" wx:if="{{categories.length > 0}}">
      <view class="section-label">
        <text class="label-icon">📂</text>
        <text class="label-text">选择分类</text>
        <text class="optional-tag">选填</text>
      </view>
      <picker 
        mode="selector" 
        range="{{categories}}" 
        range-key="categoryName"
        bindchange="onCategorySelect"
      >
        <view class="picker-display">
          <text class="{{selectedCategory ? 'selected' : 'placeholder'}}">
            {{selectedCategory ? selectedCategory.categoryName : '请选择分类'}}
          </text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- 标题输入 -->
    <view class="input-section">
      <view class="section-label">
        <text class="label-icon">💡</text>
        <text class="label-text">标题</text>
        <text class="required-tag">必填</text>
        <text class="char-count">{{title.length}}/100</text>
      </view>
      <input 
        class="title-input" 
        placeholder="给你的内容起个吸引人的标题吧（至少5个字）..." 
        placeholder-class="placeholder"
        value="{{title}}"
        bindinput="onTitleInput"
        maxlength="100"
      />
    </view>

    <!-- 内容输入 -->
    <view class="input-section">
      <view class="section-label">
        <text class="label-icon">✍️</text>
        <text class="label-text">内容</text>
        <text class="required-tag">必填</text>
        <text class="char-count">{{content.length}}/5000</text>
      </view>
      <textarea 
        class="content-textarea" 
        placeholder="分享你的想法、故事或经验（至少10个字）..." 
        placeholder-class="placeholder"
        value="{{content}}"
        bindinput="onContentInput"
        maxlength="5000"
        auto-height
        show-confirm-bar="{{false}}"
      />
    </view>

    <!-- 图片上传 -->
    <view class="media-section" wx:if="{{contentType === 'image'}}">
      <view class="section-label">
        <text class="label-icon">📷</text>
        <text class="label-text">图片</text>
        <text class="required-tag">必填</text>
        <text class="media-count">{{images.length}}/{{maxImages}}</text>
      </view>
      <view class="image-grid">
        <view class="image-item" wx:for="{{images}}" wx:key="*this">
          <image 
            src="{{item}}" 
            mode="aspectFill" 
            class="image"
            bindtap="previewImage"
            data-index="{{index}}"
          />
          <view class="delete-badge" bindtap="deleteImage" data-index="{{index}}">
            <text class="delete-icon">×</text>
          </view>
        </view>
        <view class="add-image-card" bindtap="chooseImage" wx:if="{{images.length < maxImages}}">
          <view class="add-icon-wrapper">
            <text class="add-icon">+</text>
            <text class="add-text">添加图片</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 视频上传 -->
    <view class="media-section" wx:if="{{contentType === 'video'}}">
      <view class="section-label">
        <text class="label-icon">🎥</text>
        <text class="label-text">视频</text>
        <text class="required-tag">必填</text>
      </view>
      <view class="video-wrapper" wx:if="{{videoUrl}}">
        <video src="{{videoUrl}}" class="video-player" controls/>
        <button class="remove-video-btn" bindtap="deleteVideo">
          <text class="btn-icon">🗑️</text>
          <text>删除视频</text>
        </button>
      </view>
      <view class="upload-card" wx:else bindtap="chooseVideo">
        <text class="upload-icon">📹</text>
        <text class="upload-text">点击选择视频</text>
        <text class="upload-hint">支持60秒以内的视频</text>
      </view>
    </view>

    <!-- 链接输入 -->
    <view class="input-section" wx:if="{{contentType === 'link'}}">
      <view class="section-label">
        <text class="label-icon">🌐</text>
        <text class="label-text">链接地址</text>
        <text class="required-tag">必填</text>
      </view>
      <input 
        class="link-input" 
        placeholder="请输入完整的链接地址 (https://...)" 
        placeholder-class="placeholder"
        value="{{linkUrl}}"
        bindinput="onLinkInput"
      />
    </view>

    <!-- 标签选择 -->
    <view class="tag-section" wx:if="{{tags.length > 0}}">
      <view class="section-label">
        <text class="label-icon">🏷️</text>
        <text class="label-text">添加标签</text>
        <text class="optional-tag">选填</text>
        <text class="tag-count">{{selectedTags.length}}/5</text>
      </view>
      <view class="tag-list">
        <view 
          class="tag-item {{selectedTags.indexOf(item.id) > -1 ? 'selected' : ''}}"
          wx:for="{{tags}}"
          wx:key="id"
          bindtap="onTagToggle"
          data-id="{{item.id}}"
        >
          <text class="tag-name">{{item.tagName}}</text>
        </view>
      </view>
    </view>

    <!-- 发布按钮 -->
    <view class="action-section">
      <button 
        class="publish-btn {{publishing ? 'publishing' : ''}}" 
        bindtap="onPublish"
        disabled="{{publishing}}"
      >
        <text class="btn-icon" wx:if="{{!publishing}}">🚀</text>
        <text class="btn-text">{{publishing ? '发布中...' : '立即发布'}}</text>
      </button>
      <view class="publish-hint">
        <text class="hint-icon">ℹ️</text>
        <text class="hint-text">发布后需要管理员审核通过才会显示</text>
      </view>
    </view>
  </view>
</view>
