<view class="container">
  <view class="register-box">
    <view class="header">
      <text class="title">注册账号</text>
      <text class="subtitle">加入火泰内容社区</text>
    </view>

    <view class="form-container">
      <!-- 用户名 -->
      <view class="input-group">
        <text class="input-label">用户名 <text class="required">*</text></text>
        <input 
          class="input {{usernameError ? 'input-error' : ''}}" 
          placeholder="3-20个字符，字母/数字/下划线" 
          value="{{username}}"
          bindinput="onUsernameInput"
          maxlength="20"
        />
        <text class="error-text" wx:if="{{usernameError}}">{{usernameError}}</text>
      </view>

      <!-- 密码 -->
      <view class="input-group">
        <text class="input-label">密码 <text class="required">*</text></text>
        <input 
          class="input {{passwordError ? 'input-error' : ''}}" 
          type="password"
          placeholder="6-20个字符" 
          value="{{password}}"
          bindinput="onPasswordInput"
          maxlength="20"
        />
        <text class="error-text" wx:if="{{passwordError}}">{{passwordError}}</text>
      </view>

      <!-- 确认密码 -->
      <view class="input-group">
        <text class="input-label">确认密码 <text class="required">*</text></text>
        <input 
          class="input {{confirmPasswordError ? 'input-error' : ''}}" 
          type="password"
          placeholder="请再次输入密码" 
          value="{{confirmPassword}}"
          bindinput="onConfirmPasswordInput"
          maxlength="20"
        />
        <text class="error-text" wx:if="{{confirmPasswordError}}">{{confirmPasswordError}}</text>
      </view>

      <!-- 昵称 -->
      <view class="input-group">
        <text class="input-label">昵称 <text class="required">*</text></text>
        <input 
          class="input {{nicknameError ? 'input-error' : ''}}" 
          placeholder="请输入昵称" 
          value="{{nickname}}"
          bindinput="onNicknameInput"
          maxlength="20"
        />
        <text class="error-text" wx:if="{{nicknameError}}">{{nicknameError}}</text>
      </view>

      <!-- 手机号 -->
      <view class="input-group">
        <text class="input-label">手机号</text>
        <input 
          class="input {{phoneError ? 'input-error' : ''}}" 
          type="number"
          placeholder="选填，11位手机号" 
          value="{{phone}}"
          bindinput="onPhoneInput"
          maxlength="11"
        />
        <text class="error-text" wx:if="{{phoneError}}">{{phoneError}}</text>
      </view>

      <button 
        class="register-btn" 
        bindtap="onRegister"
        disabled="{{registering}}"
      >
        {{registering ? '注册中...' : '注册'}}
      </button>

      <view class="back-login">
        <text class="back-text" bindtap="onBackToLogin">已有账号？返回登录</text>
      </view>
    </view>
  </view>
</view>
