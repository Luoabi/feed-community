page {
  background: #f7f8fa;
}

.container {
  width: 100%;
  min-height: 100vh;
  background: #f7f8fa;
}

/* 分类栏 */
.category-bar {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(255, 255, 255, 0.98);
  backdrop-filter: blur(20rpx) saturate(180%);
  -webkit-backdrop-filter: blur(20rpx) saturate(180%);
  padding: 20rpx 0;
  box-shadow: 0 2rpx 20rpx rgba(0, 0, 0, 0.03);
  margin-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.category-scroll {
  white-space: nowrap;
  padding: 0 32rpx;
}

.category-item {
  display: inline-block;
  margin-right: 20rpx;
  transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  position: relative;
}

.category-text {
  display: inline-block;
  padding: 18rpx 36rpx;
  font-size: 28rpx;
  color: #333;
  background: #f7f8fa;
  border-radius: 50rpx;
  font-weight: 500;
  transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  position: relative;
  overflow: hidden;
}

.category-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  font-size: 24rpx;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.2);
  }
}

.category-text::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  opacity: 0;
  transition: opacity 0.4s ease;
  z-index: -1;
}

.category-item.active .category-text {
  color: #fff;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.35);
  transform: translateY(-4rpx) scale(1.05);
}

.category-item.active .category-text::before {
  opacity: 1;
}

/* 内容列表 */
.content-list {
  padding: 0 32rpx 32rpx;
}

.content-card {
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 32rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.04);
  transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  position: relative;
}

.content-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 24rpx;
  padding: 2rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  opacity: 0;
  transition: opacity 0.4s ease;
}

.content-card:active {
  transform: translateY(-8rpx) scale(0.98);
  box-shadow: 0 16rpx 48rpx rgba(102, 126, 234, 0.15);
}

.content-card:active::before {
  opacity: 1;
}

/* 内容类型标签 */
.content-type-badge {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  background: linear-gradient(135deg, rgba(0, 0, 0, 0.7) 0%, rgba(0, 0, 0, 0.5) 100%);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  color: #fff;
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  font-size: 22rpx;
  z-index: 10;
  font-weight: 600;
  letter-spacing: 1rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
}

/* 封面图 */
.content-cover {
  width: 100%;
  height: 440rpx;
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, #f0f2f5 0%, #e8ecf1 100%);
}

.cover-image {
  width: 100%;
  height: 100%;
  transition: transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
  filter: brightness(0.95);
}

.content-card:active .cover-image {
  transform: scale(1.08);
  filter: brightness(1);
}

.cover-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 160rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.4) 0%, rgba(0, 0, 0, 0.1) 50%, transparent 100%);
  pointer-events: none;
}

/* 内容信息 */
.content-info {
  padding: 36rpx;
  background: #fff;
  position: relative;
}

.content-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.5;
  margin-bottom: 20rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  word-break: break-word;
  letter-spacing: 0.5rpx;
}

.content-summary {
  font-size: 28rpx;
  color: #666;
  line-height: 1.7;
  margin-bottom: 28rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  word-break: break-word;
  opacity: 0.9;
}

/* 底部信息 */
.content-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}

.author-section {
  display: flex;
  align-items: center;
  flex: 1;
}

.author-avatar {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  border: 2rpx solid rgba(102, 126, 234, 0.15);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.1);
  transition: all 0.3s ease;
  flex-shrink: 0;
}

.content-card:active .author-avatar {
  transform: scale(1.1);
  box-shadow: 0 6rpx 16rpx rgba(102, 126, 234, 0.2);
}

.author-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  flex: 1;
  min-width: 0;
}

.author-name {
  font-size: 26rpx;
  color: #666;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.publish-time {
  font-size: 22rpx;
  color: #999;
  font-weight: 400;
}

.stats-section {
  display: flex;
  align-items: center;
  gap: 28rpx;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  background: rgba(102, 126, 234, 0.05);
  border-radius: 24rpx;
  transition: all 0.3s ease;
}

.content-card:active .stat-item {
  background: rgba(102, 126, 234, 0.1);
  transform: scale(1.05);
}

.stat-icon {
  font-size: 28rpx;
  filter: grayscale(0.3);
}

.stat-text {
  font-size: 24rpx;
  color: #999;
  font-weight: 600;
}

/* 加载状态 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 5rpx solid rgba(102, 126, 234, 0.1);
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 0.8s cubic-bezier(0.68, -0.55, 0.265, 1.55) infinite;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.15);
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #999;
  font-weight: 500;
}

/* 没有更多 */
.no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  gap: 24rpx;
}

.no-more-line {
  width: 100rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(102, 126, 234, 0.3) 50%, transparent 100%);
}

.no-more-text {
  font-size: 26rpx;
  color: #999;
  font-weight: 500;
  letter-spacing: 2rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 140rpx;
  margin-bottom: 32rpx;
  opacity: 0.4;
  filter: grayscale(0.3);
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  font-weight: 500;
  letter-spacing: 1rpx;
}

/* ==================== 图片类型样式 ==================== */
.image-grid {
  position: relative;
  width: 100%;
  background: linear-gradient(135deg, #f0f2f5 0%, #e8ecf1 100%);
}

.single-image {
  width: 100%;
  height: 520rpx;
  transition: transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.content-card:active .single-image {
  transform: scale(1.05);
}

.multi-images {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 6rpx;
  position: relative;
}

.grid-image {
  width: 100%;
  height: 250rpx;
  transition: transform 0.3s ease;
}

.content-card:active .grid-image {
  transform: scale(0.98);
}

.more-images {
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  background: linear-gradient(135deg, rgba(0, 0, 0, 0.7) 0%, rgba(0, 0, 0, 0.5) 100%);
  backdrop-filter: blur(20rpx);
  color: #fff;
  padding: 10rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
}

/* ==================== 视频类型样式 ==================== */
.video-wrapper {
  /* 视频卡片的包装器 */
}

.video-container {
  position: relative;
  width: 100%;
  height: 440rpx;
  background: #000;
  overflow: hidden;
}

.video-player {
  width: 100%;
  height: 100%;
  background: #000;
}

.video-placeholder {
  position: relative;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.video-thumb {
  width: 100%;
  height: 100%;
  transition: transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
  filter: brightness(0.9);
}

.content-card:active .video-thumb {
  transform: scale(1.08);
  filter: brightness(1);
}

.video-play-btn {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(255, 255, 255, 0.85) 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #667eea;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
  transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.content-card:active .video-play-btn {
  transform: translate(-50%, -50%) scale(1.15);
  box-shadow: 0 12rpx 48rpx rgba(102, 126, 234, 0.4);
}

.video-error-tip {
  position: absolute;
  bottom: 24rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(255, 59, 48, 0.9);
  color: #fff;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(255, 59, 48, 0.3);
}

.video-duration {
  position: absolute;
  bottom: 24rpx;
  left: 24rpx;
  background: linear-gradient(135deg, rgba(0, 0, 0, 0.8) 0%, rgba(0, 0, 0, 0.6) 100%);
  backdrop-filter: blur(20rpx);
  color: #fff;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
  z-index: 5;
}

/* ==================== 链接类型样式 ==================== */
.link-preview {
  position: relative;
  width: 100%;
  height: 300rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.link-preview::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
  animation: float 8s ease-in-out infinite;
}

@keyframes float {
  0%, 100% {
    transform: translate(0, 0);
  }
  50% {
    transform: translate(-30rpx, -30rpx);
  }
}

.link-thumb {
  width: 100%;
  height: 100%;
  transition: transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.content-card:active .link-thumb {
  transform: scale(1.08);
}

.link-icon {
  font-size: 140rpx;
  opacity: 0.25;
}

/* 链接类型的内容信息区域 - 添加左边框 */
.content-info-link {
  position: relative;
  background: linear-gradient(135deg, #ffffff 0%, #fafbff 100%);
}

.content-info-link::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 8rpx;
  height: 100%;
  background: linear-gradient(180deg, #667eea 0%, #764ba2 100%);
  border-radius: 0 8rpx 8rpx 0;
}

.link-url-display {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.05) 0%, rgba(118, 75, 162, 0.05) 100%);
  border-radius: 12rpx;
  border: 1rpx solid rgba(102, 126, 234, 0.15);
  border-left: 6rpx solid #667eea;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.link-url-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.link-url-text {
  font-size: 24rpx;
  color: #667eea;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

/* ==================== 纯文本类型样式 ==================== */
.content-info-text {
  padding: 48rpx 36rpx;
  min-height: 240rpx;
  background: linear-gradient(135deg, #ffffff 0%, #fafbff 100%);
  position: relative;
}

.content-info-text::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 8rpx;
  height: 100%;
  background: linear-gradient(180deg, #667eea 0%, #764ba2 100%);
  border-radius: 0 8rpx 8rpx 0;
}
